generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  LPG
  OTHER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(EMPLOYEE)
  isActive      Boolean   @default(true)
  permissions   String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  customers          Customer[]
  vehicles           Vehicle[]
  products           Product[]
  importJobs         ImportJob[]
  offers             Offer[]
  auditLogs          AuditLog[]
  assignedWorkOrders WorkOrder[] @relation("WorkOrderTechnician")
  createdWorkOrders  WorkOrder[] @relation("WorkOrderCreatedBy")

  @@index([email])
  @@index([role])
}

model Customer {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String?  @unique
  phone       String?
  mobile      String?
  companyName String?
  taxNumber   String?
  address     String?
  city        String?
  postalCode  String?
  country     String   @default("SI")
  notes           String?  @db.Text
  defaultDiscount Decimal? @db.Decimal(5, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?

  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  vehicles    Vehicle[]
  offers      Offer[]
  workOrders  WorkOrder[]

  @@index([email])
  @@index([lastName, firstName])
  @@index([phone])
  @@index([companyName])
  @@index([isActive])
  @@index([createdAt])
}

model Vehicle {
  id                String   @id @default(cuid())
  customerId        String
  make              String
  model             String
  year              Int
  vin               String?  @unique
  registrationPlate String?
  fuelType          FuelType @default(PETROL)
  mileage           Int?
  color             String?
  notes             String?  @db.Text
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdById       String?

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  offers      Offer[]
  workOrders  WorkOrder[]

  @@index([customerId])
  @@index([vin])
  @@index([registrationPlate])
  @@index([make, model])
  @@index([year])
  @@index([isActive])
}

model Product {
  id            String   @id @default(cuid())
  productNumber String   @unique
  barcode       String?  @unique
  description   String
  brand         String?
  supplier      String?
  price         Decimal  @db.Decimal(10, 2)
  vatRate       Decimal  @db.Decimal(5, 2) @default(22.00)
  stock         Int      @default(0)
  unit          String   @default("pcs")
  substitutionPart String?
  isActive      Boolean  @default(true)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?

  createdBy      User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  offerItems     OfferItem[]
  workOrderItems WorkOrderItem[]

  @@index([productNumber])
  @@index([barcode])
  @@index([brand],    map: "product_brand_btree_idx")
  @@index([supplier], map: "product_supplier_btree_idx")
  @@index([price])
  @@index([isActive])
  @@index([isActive, productNumber], map: "product_isActive_productNumber_idx")
  @@index([productNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "product_productNumber_gin_idx")
  @@index([description(ops: raw("gin_trgm_ops"))],   type: Gin, map: "product_description_gin_idx")
  @@index([brand(ops: raw("gin_trgm_ops"))],         type: Gin, map: "product_brand_gin_idx")
  @@index([supplier(ops: raw("gin_trgm_ops"))],      type: Gin, map: "product_supplier_gin_idx")
}

enum OfferStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  COMPLETED
}

model Offer {
  id          String      @id @default(cuid())
  offerNumber String      @unique
  status      OfferStatus @default(DRAFT)
  customerId  String
  vehicleId   String?
  mileage     Int?
  currency    String      @default("EUR")
  notes               String?  @db.Text
  validUntil          DateTime?
  hideCatalogNumber   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt   DateTime    @updatedAt
  createdById String?

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items       OfferItem[]
  workOrders  WorkOrder[]

  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([createdAt])
}

model OfferItem {
  id            String  @id @default(cuid())
  offerId       String
  position      Int
  productId     String?
  productNumber String?
  description   String
  quantity      Decimal @db.Decimal(10, 3)
  unit          String  @default("pcs")
  pricePerUnit  Decimal @db.Decimal(10, 2)
  vatRate       Decimal @db.Decimal(5, 2)
  discount      Decimal @db.Decimal(5, 2) @default(0)

  offer   Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([offerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ImportJob {
  id            String       @id @default(cuid())
  status        ImportStatus @default(PENDING)
  filename      String
  filePath      String
  totalRows     Int          @default(0)
  processedRows Int          @default(0)
  insertedRows  Int          @default(0)
  updatedRows   Int          @default(0)
  deletedRows   Int          @default(0)
  errorRows     Int          @default(0)
  errors        Json         @default("[]")
  mapping       Json         @default("{}")
  syncMode      Boolean      @default(false)
  syncSupplier  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completedAt   DateTime?
  createdById   String?

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String
  entityLabel String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  changes     Json?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model PriceRule {
  id              String   @id @default(cuid())
  filterType      String   // "brand" | "supplier"
  filterValue     String
  adjustmentType  String   // "percent" | "fixed"
  adjustmentValue Decimal  @db.Decimal(10, 4)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([filterType, isActive])
}

model Settings {
  id                 String   @id @default("settings")
  companyName        String   @default("")
  companyVAT         String?
  companyAddress     String?  @db.Text
  companyEmail       String?
  companyPhone       String?
  companyLogo        String?
  defaultVATRate     Decimal  @db.Decimal(5, 2) @default(22.00)
  defaultLanguage    String   @default("en")
  currency           String   @default("EUR")
  offerPrefix        String   @default("OFF")
  invoicePrefix      String   @default("INV")
  workOrderPrefix    String   @default("WO")
  pdfFooterText         String?  @db.Text
  termsAndConditions    String?  @db.Text
  partsCatalogApiKey      String?
  partsCatalogCrossRefs   Boolean  @default(true)
  sessionTimeoutMinutes Int      @default(30)
  auditRetentionDays    Int      @default(0)
  backupSchedule        String   @default("disabled")
  backupScheduleHour    Int      @default(2)
  backupRetentionDays   Int      @default(30)
  updatedAt             DateTime @updatedAt
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  DONE
  INVOICED
  CANCELLED
}

model WorkOrder {
  id              String          @id @default(cuid())
  number          String          @unique
  status          WorkOrderStatus @default(OPEN)
  customerId      String
  vehicleId       String?
  technicianId    String?
  reportedProblem String?         @db.Text
  internalNotes   String?         @db.Text
  mileageIn       Int?
  mileageOut      Int?
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  offerId         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdById     String?

  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle    Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  technician User?           @relation("WorkOrderTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  createdBy  User?           @relation("WorkOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  offer      Offer?          @relation(fields: [offerId], references: [id], onDelete: SetNull)
  items      WorkOrderItem[]
  laborItems LaborItem[]

  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([technicianId])
  @@index([createdAt])
}

model WorkOrderItem {
  id            String    @id @default(cuid())
  workOrderId   String
  position      Int
  productId     String?
  productNumber String?
  description   String
  quantity      Decimal   @db.Decimal(10, 3)
  unit          String    @default("pcs")
  pricePerUnit  Decimal   @db.Decimal(10, 2)
  vatRate       Decimal   @db.Decimal(5, 2)
  discount      Decimal   @db.Decimal(5, 2) @default(0)
  createdAt     DateTime  @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
}

model LaborItem {
  id          String    @id @default(cuid())
  workOrderId String
  position    Int
  description String
  hours       Decimal   @db.Decimal(8, 2)
  hourlyRate  Decimal   @db.Decimal(10, 2)
  vatRate     Decimal   @db.Decimal(5, 2) @default(0)
  createdAt   DateTime  @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}
